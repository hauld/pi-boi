# LLM configuration
# Provider name - must match a known provider in @mariozechner/pi-ai (e.g. openai, anthropic, openrouter, groq)
LLM_PROVIDER=openai

# Model ID for the chosen provider
LLM_MODEL=gpt-4o-mini

# Custom API base URL - use this for OpenAI-compatible endpoints:
#   Ollama:     http://localhost:11434/v1
#   LM Studio:  http://localhost:1234/v1
#   vLLM:       http://localhost:8000/v1
#   OpenRouter: https://openrouter.ai/api/v1
# LLM_BASE_URL=http://localhost:11434/v1

# API key - alternative to storing in ~/.pi/mom/auth.json
# LLM_API_KEY=sk-...

# Core service port (default: 3030)
# PORT=3030
