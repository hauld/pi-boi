{
	"name": "pi-boi",
	"version": "0.0.1",
	"description": "boi agent",
	"type": "module",
	"bin": {
		"octo": "dist/main.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"clean": "rm -rf dist",
		"build": "tsgo -p tsconfig.build.json && chmod +x dist/main.js",
		"dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
		"dev:http": "npm run build && node dist/main.js --http ../workspace",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"dependencies": {
		"@anthropic-ai/sandbox-runtime": "^0.0.16",
		"@mariozechner/pi-agent-core": "^0.51.6",
		"@mariozechner/pi-ai": "^0.51.6",
		"@mariozechner/pi-coding-agent": "^0.51.6",
		"@sinclair/typebox": "^0.34.0",
		"@slack/socket-mode": "^2.0.0",
		"@slack/web-api": "^7.0.0",
		"chalk": "^5.6.2",
		"croner": "^9.1.0",
		"diff": "^8.0.2",
		"dotenv": "^17.3.1",
		"express": "^5.2.1"
	},
	"devDependencies": {
		"@types/diff": "^7.0.2",
		"@types/express": "^5.0.6",
		"@types/node": "^24.3.0",
		"@typescript/native-preview": "^7.0.0-dev.20260120.1",
		"typescript": "^5.7.3"
	},
	"keywords": [
		"bot",
		"ai",
		"agent"
	],
	"license": "MIT",
	"engines": {
		"node": ">=20.0.0"
	}
}
